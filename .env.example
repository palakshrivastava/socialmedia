# Copy to application-local.properties (gitignored) or export before mvnw spring-boot:run
# PostgreSQL (Neon) — use JDBC form for Spring Boot
spring.datasource.url=jdbc:postgresql://YOUR_HOST/neondb?sslmode=require
spring.datasource.username=YOUR_USER
spring.datasource.password=YOUR_PASSWORD

# MongoDB Atlas — include database name in path (/socialmedia)
spring.data.mongodb.uri=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/socialmedia?retryWrites=true&w=majority
